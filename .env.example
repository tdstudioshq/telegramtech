# Runtime
NODE_ENV=development               # production REQUIRES BOT_MODE=webhook (polling is dev-only)
LOG_LEVEL=debug                    # use info in production

# Telegram (first client adapter)
BOT_TOKEN=
BOT_MODE=polling                   # polling (dev) | webhook (production)
DEFAULT_CREATOR_SLUG=demo          # shared-bot storefront shown when /start has no ?start=c_<slug> payload
BOT_USERNAME=                      # shared-bot @username (no @), for marketplace deep-links (M7.3); optional
WEBHOOK_URL=                       # webhook mode only, e.g. https://<app>.up.railway.app/telegram/webhook
WEBHOOK_SECRET_TOKEN=              # webhook mode only — random secret; Telegram echoes it, we verify it
PORT=3000                          # health endpoint (GET /health) + webhook listener; Railway injects this

# Database (Supabase → Settings → Database)
DATABASE_URL=                      # pooler, transaction mode, port 6543 (prepare:false)
DATABASE_DIRECT_URL=               # port 5432 — migrations only

# Content storage (Supabase Storage — ADR-006)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # used ONLY by SupabaseStorageProvider; redacted in logs
STORAGE_BUCKET=drops
SIGNED_URL_TTL_SECONDS=120

# Payments
PAYMENT_PROVIDER=mock              # mock | telegram_stars (reserved)
MOCK_PAYMENT_DELAY_MS=500
MOCK_PAYMENT_FAILURE_RATE=0        # 0..1 — set >0 to exercise failure UX (Q4)

# Cache
CACHE_PROVIDER=memory              # memory | noop | redis (redis = shared cache + notification queue, M7.4)
REDIS_URL=                         # required when CACHE_PROVIDER=redis (rediss:// for TLS); backs cache + queue

# Dashboard/API auth (M7.1)
SESSION_TTL_HOURS=720              # bearer session lifetime (default 30 days)

# Jobs (minutes)
JOB_SUBSCRIPTION_SWEEP_INTERVAL=5
JOB_NOTIFICATION_INTERVAL=1
JOB_CLEANUP_INTERVAL=30
PENDING_PAYMENT_TTL_MINUTES=15     # cleanup: pending older than this → failed

# Rate limiting — Telegram bot (per Telegram user)
RATE_LIMIT_POINTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Rate limiting — JSON API (M7.3.1)
API_AUTH_RATE_LIMIT_POINTS=10        # login/register attempts per client IP per window
API_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
API_PUBLIC_RATE_LIMIT_POINTS=60      # public marketplace reads per client IP per window
API_PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_POINTS=120            # authenticated requests per creator per window (incl. uploads)
API_RATE_LIMIT_WINDOW_SECONDS=60
API_TRUSTED_PROXY_HOPS=1             # appending reverse proxies in front of the app (Railway edge = 1)
